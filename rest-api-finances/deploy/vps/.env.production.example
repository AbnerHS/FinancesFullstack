DB_HOST=mysql-db
DB_PORT=3306
DB_NAME=finances
DB_USERNAME=finances_user
DB_PASSWORD=
MYSQL_ROOT_PASSWORD=

SPRING_DATASOURCE_URL=jdbc:mysql://${DB_HOST}:${DB_PORT}/${DB_NAME}?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC

SERVER_PORT=8080
APP_TRANSACTION_DOCUMENTS_DIR=/app/data/payment-documents

JWT_ACCESS_TOKEN_SECRET=
JWT_REFRESH_TOKEN_SECRET=
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000
JWT_REFRESH_COOKIE_SECURE=true
JWT_REFRESH_COOKIE_SAME_SITE=None

APP_CORS_ALLOWED_ORIGINS=https://finances-fullstack.vercel.app
APP_CORS_ALLOWED_ORIGIN_PATTERNS=

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://finances-fullstack.vercel.app/auth/google/callback
